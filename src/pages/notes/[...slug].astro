---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.data._slug },
    props: { note, allNotes: notes },
  }));
}

const { note, allNotes } = Astro.props;
const { Content } = await render(note);

const statusEmoji = (s: string) => {
  if (s === 'active') return '🌿';
  if (s === 'evergreen') return '🌳';
  return '🌱';
};

// W2.4 TL;DR 自動生成（純前端，build-time 算）
// 不靠 LLM（subscription expired）— 從 body 抽首段純文字
function extractTLDR(body: string, maxLen = 240): string {
  if (!body) return '';
  let text = body;
  // 移除 frontmatter
  text = text.replace(/^---\n[\s\S]*?\n---\n/, '');
  // 移除 H1
  text = text.replace(/^#\s+.*$/m, '');
  // 移除 blockquote (>) 開頭
  text = text.replace(/^>.*$/gm, '');
  // 移除 details / summary 標籤
  text = text.replace(/<\/?details>|<summary>[\s\S]*?<\/summary>/g, '');
  // 移除 Hugo/Astro shortcode（配對 {{< ... >}} 跟 {{</...>}}）
  text = text.replace(/\{\{<\/?[^}>]*>?\}\}/g, '');
  // 一般 shortcode 兜底
  text = text.replace(/\{\{[\s\S]*?\}\}/g, '');
  // 移除 code block
  text = text.replace(/```[\s\S]*?```/g, '');
  // 移除 markdown 標記（list / heading / link syntax）
  text = text.replace(/^[\-\*#]+\s*/gm, '');
  text = text.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1');
  text = text.replace(/[*_`]/g, '');
  // 移除多餘空行 / 空格
  text = text.replace(/\n+/g, ' ').replace(/\s+/g, ' ').trim();
  // 截斷到 maxLen
  if (text.length > maxLen) text = text.slice(0, maxLen).trim() + '…';
  return text;
}
const tldr = extractTLDR(note.body || '');

const base = import.meta.env.BASE_URL;

// W3.3 相關筆記：找同 tag 的其他 notes，優先 type 相同的
const noteTags = new Set(note.data.tags || []);
const sameTags = allNotes
  .filter((n) => n.data._slug !== note.data._slug)
  .map((n) => {
    const overlap = (n.data.tags || []).filter((t: string) => noteTags.has(t)).length;
    return { note: n, overlap, sameType: n.data.type === note.data.type };
  })
  .filter((x) => x.overlap > 0)
  .sort((a, b) => {
    // 優先：同 type > tag overlap 多 > updated 新
    if (a.sameType !== b.sameType) return a.sameType ? -1 : 1;
    if (a.overlap !== b.overlap) return b.overlap - a.overlap;
    return (b.note.data.updated || '').localeCompare(a.note.data.updated || '');
  })
  .slice(0, 5)
  .map((x) => x.note);

// 隨機發現：從 allNotes 隨機挑 3 篇
const randomPicks = allNotes
  .filter((n) => n.data._slug !== note.data._slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);
---

<Layout title={`${note.data.title} | Hestia KB`} description={note.data.title}>
  <article class="prose-hestia max-w-3xl">
    <!-- Frontmatter header -->
    <header class="mb-8 pb-6 border-b border-hestia-border">
      <div class="flex items-center gap-2 text-xs text-hestia-muted tracking-widest uppercase mb-3">
        <span>{note.data.type || 'note'}</span>
        <span>·</span>
        <span title={note.data.status || 'seedling'}>
          {statusEmoji(note.data.status || 'seedling')} {note.data.status || 'seedling'}
        </span>
        {note.data.created && (
          <>
            <span>·</span>
            <span>{note.data.created}</span>
          </>
        )}
      </div>

      <h1 class="text-3xl md:text-4xl font-serif font-semibold text-hestia-ink mb-4 leading-tight">
        {note.data.title}
      </h1>

      {note.data.tags && note.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 text-xs">
          {note.data.tags.map((tag: string) => (
            <a
              href={`${base}/tags/${encodeURIComponent(tag)}/`}
              class="px-2 py-0.5 bg-hestia-accent/10 text-hestia-accent rounded hover:bg-hestia-accent/20 no-underline"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}

      {note.data._vault_path && (
        <p class="text-xs text-hestia-muted/50 mt-3 font-mono">
          vault: {note.data._vault_path}
        </p>
      )}
    </header>

    <!-- W2.4 TL;DR（自動生成） -->
    {tldr && (
      <aside class="mb-8 p-4 bg-hestia-cream/60 border-l-4 border-hestia-accent rounded-r-md">
        <p class="text-xs uppercase tracking-widest text-hestia-accent font-semibold mb-1">
          一句話總結
        </p>
        <p class="text-hestia-ink leading-relaxed">
          {tldr}
        </p>
      </aside>
    )}

    <!-- Body -->
    <div class="prose prose-hestia">
      <Content />
    </div>

    <!-- W3.3 相關筆記 -->
    {sameTags.length > 0 && (
      <aside class="mt-12 pt-6 border-t border-hestia-border">
        <h2 class="text-xl font-serif font-semibold text-hestia-ink mb-4">
          📚 相關筆記
        </h2>
        <ul class="space-y-2">
          {sameTags.map((n) => (
            <li>
              <a href={`${base}/notes/${n.data._slug}/`} class="block py-1 hover:text-hestia-accent no-underline">
                <span class="text-hestia-muted text-sm mr-2">{n.data.type}</span>
                <span class="text-hestia-ink">{n.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <!-- 隨機發現 -->
    <aside class="mt-8 pt-6 border-t border-hestia-border/50">
      <h3 class="text-sm font-serif text-hestia-muted mb-3">🎲 隨機發現</h3>
      <ul class="space-y-1 text-sm">
        {randomPicks.map((n) => (
          <li>
            <a href={`${base}/notes/${n.data._slug}/`} class="text-hestia-muted hover:text-hestia-accent no-underline">
              {n.data.title}
            </a>
          </li>
        ))}
      </ul>
    </aside>

    <!-- 底部導航 -->
    <nav class="mt-8 pt-6 border-t border-hestia-border flex justify-between text-sm">
      <a href={`${base}/notes/`} class="text-hestia-accent">← 回到筆記目錄</a>
      <a href={`${base}/`} class="text-hestia-accent">首頁 →</a>
    </nav>
  </article>
</Layout>
