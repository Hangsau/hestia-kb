---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

// 示範資料：手動列幾個有內容的 vault 筆記
const sampleNotes = [
  {
    title: "Hermes Profile Audit — Hestia + Talos Inventory",
    path: "notes/hermes-profile-audit/",
    type: "research",
    status: "active",
    date: "2026-05-27",
    desc: "Psyche 對 Hestia/Talos 兩個 profile 的完整審計。35+ 自建 script、10 個 active cron、Heartbeat V2 雙層設計、Memory pipeline 完整鏈路。",
    tags: ["hermes", "audit", "hestia", "talos", "profile"]
  },
  {
    title: "Hestia 筆記",
    path: "notes/hestia-log/",
    type: "project",
    status: "active",
    date: "2026-05-17",
    desc: "Hestia 從 2026-05-17 開始的工作 log。包含 Ring 2 解除、compression warning 拍板、風格基準建立。",
    tags: ["hestia", "log", "project"]
  },
];

const statusEmoji = (s: string) => {
  if (s === "active") return "🌿";
  if (s === "evergreen") return "🌳";
  return "🌱";
};
---

<Layout title="Hestia KB — 個人知識庫數位花園">
  <!-- Hero -->
  <section class="py-12 md:py-16">
    <p class="text-hestia-muted text-sm tracking-widest uppercase mb-3">Hestia KB</p>
    <h1 class="text-4xl md:text-5xl font-serif font-semibold text-hestia-ink mb-6 leading-tight">
      個人知識庫，<br />
      <span class="text-hestia-accent">會思考的索引層</span>。
    </h1>
    <p class="text-lg text-hestia-muted max-w-2xl leading-relaxed">
      這是一座「可被外人探索的個人知識宇宙」—— 1196 篇 Obsidian 筆記、12 個領域、1947 個 FTS5 chunks。
      Hestia 幫你整理、連結、摘要；你只讀網站，不讀原始檔。
    </p>
    <div class="mt-8 flex gap-3 text-sm">
      <a href={`${base}/notes/`} class="px-4 py-2 bg-hestia-accent text-hestia-cream rounded-md no-underline hover:bg-hestia-accent/90">
        開始探索 →
      </a>
      <a href="#knowledge-map" class="px-4 py-2 border border-hestia-border text-hestia-ink rounded-md no-underline hover:bg-hestia-border/30">
        看知識地圖
      </a>
    </div>
  </section>

  <!-- 知識地圖（佔位 — 之後接 vis-network） -->
  <section id="knowledge-map" class="py-10 border-t border-hestia-border">
    <h2 class="text-2xl font-serif font-semibold mb-2">知識地圖</h2>
    <p class="text-hestia-muted text-sm mb-6">
      🌱 seedling (剛長) · 🌿 budding (成長中) · 🌳 evergreen (成熟)
    </p>
    <div class="border border-hestia-border rounded-lg p-12 bg-hestia-cream/50 text-center text-hestia-muted">
      <p class="mb-2">🗺️</p>
      <p>知識地圖渲染區</p>
      <p class="text-xs mt-2">
        下一階段：vis-network 跑 1196 個節點 + wikilink 邊
      </p>
    </div>
  </section>

  <!-- 近期照料（示範） -->
  <section class="py-10 border-t border-hestia-border">
    <h2 class="text-2xl font-serif font-semibold mb-6">近期照料</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {sampleNotes.map((note) => (
        <a
          href={`${base}/${note.path}`}
          class="block border border-hestia-border rounded-lg p-5 hover:border-hestia-accent-soft transition-colors no-underline bg-hestia-cream/30"
        >
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-serif font-semibold text-hestia-ink leading-snug">
              {note.title}
            </h3>
            <span class="text-xl shrink-0" title={note.status}>{statusEmoji(note.status)}</span>
          </div>
          <p class="text-sm text-hestia-muted leading-relaxed mb-3">
            {note.desc}
          </p>
          <div class="flex flex-wrap gap-1.5 text-xs">
            {note.tags.map((tag) => (
              <span class="px-2 py-0.5 bg-hestia-accent/10 text-hestia-accent rounded">
                #{tag}
              </span>
            ))}
          </div>
          <p class="text-xs text-hestia-muted/70 mt-3">{note.date} · {note.type}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- 領域分佈 -->
  <section class="py-10 border-t border-hestia-border">
    <h2 class="text-2xl font-serif font-semibold mb-6">領域分佈</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-sm">
      {[
        { name: "30-Areas", count: 403, color: "status-evergreen" },
        { name: "40-Resources", count: 749, color: "status-budding" },
        { name: "20-Projects", count: 16, color: "status-seedling" },
        { name: "10-Daily", count: 10, color: "status-seedling" },
        { name: "99-Templates", count: 2, color: "status-budding" },
        { name: "research (legacy)", count: 17, color: "status-budding" },
      ].map((area) => (
        <div class="border border-hestia-border rounded-md p-3 hover:bg-hestia-cream/50">
          <div class={`text-xs ${area.color} mb-1`}>●</div>
          <div class="font-mono text-hestia-ink">{area.name}</div>
          <div class="text-hestia-muted text-xs">{area.count} 個 .md</div>
        </div>
      ))}
    </div>
  </section>

  <!-- 設計理念 -->
  <section class="py-10 border-t border-hestia-border">
    <h2 class="text-2xl font-serif font-semibold mb-4">設計理念</h2>
    <ul class="space-y-2 text-hestia-muted leading-relaxed max-w-2xl">
      <li><span class="text-hestia-accent">●</span> 寫入要明確觸發（TG 對話預設不寫入 vault）</li>
      <li><span class="text-hestia-accent">●</span> 人類可審閱（自動產出先進 staging，user 確認才入主 vault）</li>
      <li><span class="text-hestia-accent">●</span> 不取代 Obsidian（vault 仍是 source of truth）</li>
      <li><span class="text-hestia-accent">●</span> 可逆（任何批次改動前先備份 + 留 undo script）</li>
      <li><span class="text-hestia-accent">●</span> 守護者可見（每個 phase 都要讓守護者看得到狀態）</li>
    </ul>
  </section>
</Layout>
